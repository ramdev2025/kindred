# ============================================
# Environment & Secrets
# ============================================
.env
.env.*
!.env.example

# ============================================
# Backend (Node.js / Express)
# ============================================
backend/node_modules/
backend/dist/
backend/.env*
backend/uploads/*
!backend/uploads/.gitkeep

# ============================================
# Frontend (Next.js)
# ============================================
frontend/node_modules/
frontend/.pnp
frontend/.pnp.*
frontend/.yarn/*
!frontend/.yarn/patches
!frontend/.yarn/plugins
!frontend/.yarn/releases
!frontend/.yarn/versions
frontend/.next/
frontend/out/
frontend/build/
frontend/coverage/
frontend/.env*
frontend/.vercel
frontend/*.tsbuildinfo
frontend/next-env.d.ts

# ============================================
# Python Service (Hermes Worker)
# ============================================
service/__pycache__/
service/*.py[oc]
service/build/
service/dist/
service/wheels/
service/*.egg-info
service/.venv/
service/.env*

# ============================================
# OS & Editor
# ============================================
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/

# ============================================
# Debug & Logs
# ============================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ============================================
# Security - Never commit these
# ============================================
*.pem
*.key
*.cert
credentials.json
service-account.json
