# ============================================
# Kindred AI Studio — Environment Variables
# Copy this file to .env and fill in your keys
# ============================================

# --- Clerk Authentication ---
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# --- Google AI (choose one backend) ---

# Option A: AI Studio (simpler, no GCP project needed)
GOOGLE_GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# Option B: Vertex AI (recommended for production — uses Application Default Credentials)
# GOOGLE_GENAI_USE_VERTEXAI=TRUE
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# Model override (defaults to gemini-2.0-flash if not set)
GEMINI_MODEL=gemini-2.0-flash

# --- E2B Sandbox ---
E2B_API_KEY=e2b_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- PostgreSQL ---
DATABASE_URL=postgresql://vibe_user:vibe_password@localhost:5432/vibe_coding

# --- Backend Server ---
PORT=3001
NODE_ENV=development

# --- Deep Research ADK Service ---
RESEARCH_SERVICE_URL=http://localhost:8000

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# --- GitHub OAuth ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3001/api/github/callback

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/google/callback

# --- Deployment Targets (optional) ---
VERCEL_TOKEN=
NETLIFY_TOKEN=
GCP_SERVICE_ACCOUNT_JSON=

# --- Vercel Blob Storage (file uploads) ---
BLOB_READ_WRITE_TOKEN=

# --- Database Connection Encryption ---
DB_ENCRYPTION_KEY=your-32-char-encryption-key-here

# --- SQLite (local quota + rate limiting store) ---
SQLITE_PATH=./data/kindred.db

# --- PayPal Integration ---
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENVIRONMENT=sandbox
