# ============================================
# Vibe Coding Webapp - Environment Variables
# Copy this file to .env and fill in your keys
# ============================================

# --- Clerk Authentication ---
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# --- Google Gemini ---
GOOGLE_GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- OpenAI (GPT-5.4) ---
OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- E2B Sandbox ---
E2B_API_KEY=e2b_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- PostgreSQL ---
DATABASE_URL=postgresql://vibe_user:vibe_password@localhost:5432/vibe_coding

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Backend Server ---
PORT=3001
NODE_ENV=development

# --- Hermes Worker ---
HERMES_WORKER_URL=http://localhost:8000

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:3001

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3001/api/github/callback

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/google/callback

# Deployment Targets
VERCEL_TOKEN=
NETLIFY_TOKEN=
GCP_SERVICE_ACCOUNT_JSON=

# Database Connection Encryption
DB_ENCRYPTION_KEY=your-32-char-encryption-key-here
